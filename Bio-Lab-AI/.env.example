# ─────────────────────────────────────────────
#  Lab Copilot — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# PostgreSQL connection string
# Neon (free): grab from neon.tech dashboard
# Railway: copy from your Railway PostgreSQL plugin dashboard
# Local dev: postgresql://localhost:5432/lab_copilot
DATABASE_URL=<postgresql-connection-string>

# ── Google Gemini AI ──────────────────────────
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=<google-gemini-api-key>
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite

# ── API safety limits ─────────────────────────
# Defaults shown here: 20 AI requests/user/15 minutes and 5MB JSON bodies.
AI_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_WINDOW_MS=900000
AI_INPUT_MAX_CHARS=8000
REQUEST_BODY_LIMIT=5mb

# Comma-separated browser origins allowed to call the API with credentials.
# In dev, localhost/127.0.0.1 origins are allowed automatically.
# In production, set this to your frontend origin, e.g. https://your-app.vercel.app
CORS_ORIGINS=

# ── Clerk Authentication (server) ─────────────
# OPTIONAL in local dev — leave blank to run in demo mode (no login required)
# REQUIRED when NODE_ENV=production
# Get from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=

# ── Admin access ──────────────────────────────
# Comma-separated list of emails that can access /admin routes.
# In production, the backend reads this from Clerk session claims, not client headers.
ADMIN_EMAILS=you@example.com

# ─────────────────────────────────────────────
#  Frontend (Vite) — prefix all with VITE_
#  These are bundled into the client build
# ─────────────────────────────────────────────

# Clerk publishable key — OPTIONAL, leave blank for demo mode
VITE_CLERK_PUBLISHABLE_KEY=

# Admin email shown in the frontend UI for admin checks
VITE_ADMIN_EMAIL=you@example.com

# API base URL — set when frontend (Vercel) and API (Render) are on different origins
# e.g. https://lab-copilot-api.onrender.com
# Leave blank when running locally or when API and frontend share the same domain
VITE_API_URL=
