# ─────────────────────────────────────────────
#  Lab Copilot — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
# PostgreSQL connection string
# Neon (free): grab from neon.tech dashboard
# Railway: copy from your Railway PostgreSQL plugin dashboard
# Local dev: postgresql://localhost:5432/lab_copilot
DATABASE_URL=<postgresql-connection-string>

# ── Bio-Lab AI (Cloudflare Workers AI) ───────
# Create an API token with Workers AI Read + Write permissions.
# The LoRA id stays blank until the Colab-trained adapter passes evaluation.
AI_PROVIDER=cloudflare
CLOUDFLARE_ACCOUNT_ID=<cloudflare-account-id>
CLOUDFLARE_API_TOKEN=<cloudflare-workers-ai-token>
CLOUDFLARE_MODEL=@cf/mistral/mistral-7b-instruct-v0.2-lora
CLOUDFLARE_LORA_ID=
AI_PROVIDER_TIMEOUT_MS=90000
# Set false only when generation metadata/correction collection must be disabled.
AI_RECORD_GENERATIONS=true

# ── API safety limits ─────────────────────────
# Defaults shown here: 20 AI requests/user/15 minutes and 5MB JSON bodies.
AI_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_WINDOW_MS=900000
AI_DAILY_REQUEST_LIMIT=50
# Staged rollout: 0 = owner IDs only; then set 10, 50, and 100 after each gate.
AI_ROLLOUT_PERCENT=0
AI_ROLLOUT_OWNER_USER_IDS=user_123
AI_INPUT_MAX_CHARS=8000
REQUEST_BODY_LIMIT=5mb
API_RATE_LIMIT_MAX=600
API_RATE_LIMIT_WINDOW_MS=900000

# Comma-separated browser origins allowed to call the API with credentials.
# In dev, localhost/127.0.0.1 origins are allowed automatically.
# https://biolab-copilot.vercel.app is allowed by default for the deployed app.
# In production, set this when adding another frontend origin, e.g. https://your-app.vercel.app
CORS_ORIGINS=
# Opt in only when you intentionally use arbitrary Vercel preview URLs.
ALLOW_VERCEL_PREVIEWS=false

# ── Clerk Authentication (server) ─────────────
# Required by default. Local demo mode must be explicitly enabled below.
# REQUIRED when NODE_ENV=production
# Get from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=

# Local development only. Demo mode is refused in production.
ENABLE_DEMO_MODE=false
# Optional: to test admin UI in demo mode, this must also appear in ADMIN_EMAILS.
DEMO_ADMIN_EMAIL=

# ── Admin access ──────────────────────────────
# Comma-separated list of emails that can access /admin routes.
# In production, the backend reads this from Clerk session claims, not client headers.
ADMIN_EMAILS=you@example.com

# Comma-separated Clerk user IDs allowed to inspect/export approved AI training data.
# Use demo_user only for local demo mode. Never expose this list to the frontend.
AI_TRAINING_ADMIN_USER_IDS=user_123

# ─────────────────────────────────────────────
#  Frontend (Vite) — prefix all with VITE_
#  These are bundled into the client build
# ─────────────────────────────────────────────

# Clerk publishable key. Missing keys never enable demo mode in production.
VITE_CLERK_PUBLISHABLE_KEY=

# Explicit local-development escape hatch. Never works in production builds.
VITE_ENABLE_DEMO_MODE=false
VITE_ENABLE_DEMO_ADMIN=false

# Admin email shown in the frontend UI for admin checks
VITE_ADMIN_EMAIL=you@example.com

# API base URL — set when frontend (Vercel) and API (Render) are on different origins
# e.g. https://lab-copilot-api.onrender.com
# Leave blank when running locally or when API and frontend share the same domain
VITE_API_URL=
